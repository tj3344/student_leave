# ============================================
# 1Panel 部署环境变量配置模板
# ============================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据实际部署情况修改配置
# 3. 在 1Panel 运行环境配置中添加这些环境变量

# ============================================
# Node 环境（必填）
# ============================================
NODE_ENV=production

# ============================================
# 数据库连接（必填）
# ============================================
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# 示例：postgresql://student_leave:mypassword@127.0.0.1:5432/student_leave
#
# 注意事项：
# 1. 主机地址：如果数据库和应用在同一服务器，使用 127.0.0.1
# 2. 如果使用 1Panel 的数据库服务，可以使用数据库容器名
# 3. 确保密码中不包含特殊字符（如 @ : / 等），或使用 URL 编码
POSTGRES_URL=postgresql://student_leave:YOUR_DB_PASSWORD@127.0.0.1:5432/student_leave

# ============================================
# 安全密钥（必填）
# ============================================

# 数据库加密密钥（必填）
# 用途：加密数据库中的敏感信息
# 格式：64位十六进制字符（32字节）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 示例：a1b2c3d4e5f6...（共64个字符）
DB_ENCRYPTION_KEY=YOUR_64_CHAR_HEX_KEY_HERE

# CSRF 保护密钥（必填）
# 用途：防止跨站请求伪造攻击
# 格式：64位十六进制字符（32字节）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=YOUR_64_CHAR_HEX_KEY_HERE

# 会话密钥（必填）
# 用途：加密用户会话数据
# 格式：任意长度的随机字符串（建议使用 base64 编码）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=YOUR_SESSION_SECRET_HERE

# ============================================
# 应用配置（必填）
# ============================================

# 应用公开访问 URL（必填）
# 用途：生成正确的链接和回调地址
# 格式：完整的 URL，包含协议、主机、端口
# 开发环境示例：http://localhost:3000
# 生产环境示例：http://192.168.1.100:3000 或 https://your-domain.com
NEXT_PUBLIC_APP_URL=http://YOUR_SERVER_IP:PORT

# ============================================
# 可选配置
# ============================================

# 服务端口（可选，默认 3000）
# 通常不需要修改，由 1Panel 端口映射控制
# PORT=3000

# 日志目录（可选）
# 默认：应用根目录下的 logs 文件夹
# LOG_DIR=/opt/student_leave/logs

# 备份目录（可选）
# 默认：应用根目录下的 backups 文件夹
# BACKUP_DIR=/opt/student_leave/backups

# ============================================
# 密钥生成快速命令
# ============================================
# 在终端中执行以下命令生成所需密钥：
#
# 生成数据库加密密钥：
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 生成 CSRF 密钥：
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 生成会话密钥：
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# ============================================
# 1Panel 配置示例
# ============================================
# 在 1Panel 运行环境的环境变量配置中，逐个添加上述变量。
#
# 例如：
# - 变量名：NODE_ENV
# - 变量值：production
#
# - 变量名：POSTGRES_URL
# - 变量值：postgresql://student_leave:mypass123@127.0.0.1:5432/student_leave
#
# ============================================
