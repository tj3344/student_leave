# ============================================
# Docker 部署环境变量配置示例
# ============================================
# 使用方法:
# 1. 复制此文件为 .env: cp .env.docker.example .env
# 2. 运行密钥生成脚本: node scripts/generate-secrets.js
# 3. 将生成的密钥填入下方对应位置
# 4. 设置 PostgreSQL 密码
# 5. 运行: docker-compose --profile with-postgres up -d

# ============================================
# PostgreSQL 数据库配置
# ============================================

# 数据库用户名
POSTGRES_USER=student_leave

# 数据库密码 (必须修改为强密码)
POSTGRES_PASSWORD=your-secure-password-here

# 数据库名称
POSTGRES_DB=student_leave

# PostgreSQL 连接字符串 (修改 your-password-here 为上面设置的密码)
# 格式: postgresql://用户名:密码@主机:端口/数据库名
POSTGRES_URL=postgresql://student_leave:your-password-here@postgres:5432/student_leave

# PostgreSQL 网络名称 (如果使用外部 PostgreSQL 容器)
POSTGRES_NETWORK_NAME=postgres-network

# ============================================
# 安全密钥配置 (必须修改!)
# ============================================

# 数据库加密密钥 (64位十六进制)
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=your-64-character-hex-key-here

# CSRF Token 签名密钥 (64位十六进制)
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=your-64-character-hex-key-here

# 会话密钥
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=your-secret-key-change-this-in-production

# ============================================
# 应用配置
# ============================================

# 运行环境
NODE_ENV=production

# 应用 URL (生产环境请修改为实际域名)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 最大文件上传大小 (字节，默认 10MB)
MAX_FILE_SIZE=10485760

# ============================================
# Docker 容器配置
# ============================================

# 容器用户 UID/GID (需与 Dockerfile 中创建的用户一致)
DOCKER_UID=1001
DOCKER_GID=1001

# ============================================
# 可选配置
# ============================================

# 日志目录 (默认: ./logs)
# LOG_DIR=/path/to/logs

# 备份目录 (默认: ./backups)
# BACKUP_DIR=/path/to/backups
