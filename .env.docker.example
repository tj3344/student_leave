# ============================================
# Docker 部署环境变量配置示例
# ============================================
# 使用方法:
# 1. 复制此文件为 .env: cp .env.docker.example .env
# 2. 运行密钥生成脚本: node scripts/generate-secrets.js
# 3. 将生成的密钥填入下方对应位置
# 4. 设置 PostgreSQL 密码
# 5. 运行: docker-compose --profile with-postgres up -d

# ============================================
# PostgreSQL 数据库配置
# ============================================

# 数据库用户名
POSTGRES_USER=student_leave

# 数据库密码 (默认密码，生产环境建议修改)
POSTGRES_PASSWORD=student_leave_pass

# 数据库名称
POSTGRES_DB=student_leave

# PostgreSQL 连接字符串
# 格式: postgresql://用户名:密码@主机:端口/数据库名
POSTGRES_URL=postgresql://student_leave:student_leave_pass@postgres:5432/student_leave

# PostgreSQL 网络名称 (如果使用外部 PostgreSQL 容器)
POSTGRES_NETWORK_NAME=postgres-network

# ============================================
# 安全密钥配置
# ============================================

# 数据库加密密钥 (64位十六进制)
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# CSRF Token 签名密钥 (64位十六进制)
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# 会话密钥
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=c29tZS1zZWNyZXQta2V5LWZvci1zZXNzaW9u

# ============================================
# 应用配置
# ============================================

# 运行环境
NODE_ENV=production

# 应用 URL (生产环境请修改为实际域名)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 最大文件上传大小 (字节，默认 10MB)
MAX_FILE_SIZE=10485760

# ============================================
# Docker 容器配置
# ============================================

# 容器用户 UID/GID (需与 Dockerfile 中创建的用户一致)
DOCKER_UID=1001
DOCKER_GID=1001

# ============================================
# 可选配置
# ============================================

# 日志目录 (默认: ./logs)
# LOG_DIR=/path/to/logs

# 备份目录 (默认: ./backups)
# BACKUP_DIR=/path/to/backups
