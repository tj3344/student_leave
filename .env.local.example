# PostgreSQL 数据库连接（必需）
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# 示例：postgresql://postgres:password@localhost:5432/student_leave
POSTGRES_URL=postgresql://postgres:password@localhost:5432/student_leave

# 数据库加密密钥（必需）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 注意：必须是 64 位十六进制字符（32字节）
DB_ENCRYPTION_KEY=your-64-character-hex-key-here

# CSRF Token 签名密钥（必需，生产环境必须设置）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 注意：必须是 64 位十六进制字符（32字节）
CSRF_SECRET=your-64-character-hex-key-here

# 会话密钥（必需）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=your-secret-key-change-this-in-production

# 运行环境（必需）
# 可选值：development, production, test
NODE_ENV=development

# 应用 URL（必需）
# 生产环境应使用 HTTPS 地址
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# 可选环境变量
# ============================================

# 日志目录（可选，默认：项目根目录下的 logs 文件夹）
# LOG_DIR=/path/to/logs

# 日志文件最大大小（可选，默认：10485760 字节 = 10MB）
# LOG_MAX_SIZE=10485760

# 日志文件保留数量（可选，默认：5 个）
# LOG_MAX_FILES=5

# 备份目录（可选，默认：项目根目录下的 backups 文件夹）
# BACKUP_DIR=/path/to/backups

# 是否启用文件日志（可选，生产环境默认启用）
# ENABLE_FILE_LOG=true
